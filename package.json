{
  "name": "the-noumenon-library",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "db:migrate": "DATABASE_URL=postgresql://localhost:5432/tnl node scripts/migrate.mjs",
    "db:migrate:preview": "vercel env pull --environment=preview .env.preview.tmp && node --env-file=.env.preview.tmp scripts/migrate.mjs; rm -f .env.preview.tmp",
    "db:migrate:prod": "node --env-file=.env.prod scripts/migrate.mjs",
    "takedown": "node --env-file=.env.local scripts/takedown.mjs",
    "invite": "node --env-file=.env.local scripts/invite.mjs",
    "invite:preview": "node --env-file=.env.preview scripts/invite.mjs",
    "backup": "node --env-file-if-exists=.env.local scripts/backup.mjs",
    "restore:verify": "node --env-file-if-exists=.env.local scripts/restore-verify.mjs",
    "wander": "node scripts/wander-sample.mjs",
    "deploy:prod": "git push origin main:prod"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "next": "16.2.7",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
