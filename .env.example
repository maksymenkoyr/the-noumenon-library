# The Noumenon Library — server-only environment variables. All are read in
# lib/config.ts (docs/reference/architecture.md §11); none are NEXT_PUBLIC_* — no
# provider key or secret ever reaches the client. Copy to .env.local for
# local dev (`node --env-file=.env.local`, or Next's built-in .env.local
# loading) and fill in the values you need.

# --- Model providers (docs/reference/architecture.md §6, model-pool rework) ----------
# Both providers speak the OpenAI-compatible chat-completions API (lib/
# providers.ts). A provider with no key set just has its model_registry rows
# filtered out of selection (lib/registry.ts) — the app still serves cache
# hits with zero keys configured, it just can't generate anything new.
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# --- Database (Neon Postgres, docs/reference/architecture.md §8/§11) -----------------
DATABASE_URL=
# Unpooled connection string — used only by the nightly backup job
# (scripts/backup.mjs), not by the app itself.
DATABASE_URL_UNPOOLED=TRUE

# --- Dev / moderation toggles -----------------------------------------------
# Console-log which model each generation/moderation call runs. Defaults to
# on outside production.
DEV_MODE=
# Safety gate; on by default. Set to false ONLY as a temporary local unblock —
# pages generated while off are stored UNMODERATED (docs/reference/architecture.md §7).
MODERATION_ENABLED=
# TEMPORARY production escape valve for MODERATION_ENABLED=false. Must be
# unset before any genuinely public launch.
ALLOW_UNMODERATED=

# --- Generation entropy levers (docs/reference/generation.md) -------------------------
GENERATION_TEMPERATURE=
GENERATION_TEMPERATURE_JITTER=
PAGE_MAX_WORDS=
# Cost backstop for the aux generation-pool calls (book title/tags,
# condensation) that don't have their own model_registry row — the real
# per-call cap for generation/moderation proper is the chosen model_registry
# row's max_tokens. Lowered from 4000: reasoning is off on every call now, so
# no budget is lost to reasoning tokens before any page text.
GENERATION_MAX_TOKENS=1000

# --- Books experiment (docs/reference/books.md), default off --------------------------
BOOK_MODE=
CONDENSED_MIDDLE_MAX_WORDS=
CONDENSE_MIN_MIDDLE_WORDS=

# --- Concurrency guards (docs/reference/architecture.md §3) ---------------------------
# Lowered from 300: with reasoning off, worst-case generation latency dropped
# well below the old reasoning-model blank-pause window.
STALE_RESERVATION_SECONDS=90
GENERATION_WAIT_SECONDS=
WAIT_POLL_INTERVAL_MS=

# --- Economics & safety (docs/reference/architecture.md §10) --------------------------
RATE_LIMIT_PER_MINUTE=
RATE_LIMIT_WINDOW_SECONDS=
# Second, looser tier on the same per-IP counter — catches a visitor pacing
# just under the per-minute ceiling but still hammering the library over an
# hour. Checked in addition to, not instead of, the per-minute limit above.
RATE_LIMIT_PER_HOUR=
RATE_LIMIT_HOUR_WINDOW_SECONDS=
MONTHLY_SPEND_CAP_USD=
ENGAGEMENT_RATE_LIMIT_PER_MINUTE=
ENGAGEMENT_RATE_LIMIT_WINDOW_SECONDS=
RATE_LIMIT_SALT=
# modelId@usdPerMillionTokens, comma-separated — overrides the interim
# defaults seeded in lib/config.ts (DEFAULT_MODEL_PRICES). See the TODO there:
# hand-maintained, follow-up is live catalog pricing.
MODEL_PRICES=

# --- Alerting & reports (docs/reference/architecture.md §9, legal.md) -----------------
MONITOR_WEBHOOK_URL=
REPORT_CONTACT_EMAIL=
RESEND_API_KEY=
REPORT_NOTIFY_EMAIL=
REPORT_FROM_EMAIL=

# --- Private-access gate (proxy.ts, lib/access.ts) --------------------------
# Unset = gate is inert, site is open.
ACCESS_SIGNING_SECRET=

# --- Nightly backup job (scripts/backup.mjs, CI secrets, not app env) ------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
